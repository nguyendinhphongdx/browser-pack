{
  "name": "browserpack",
  "version": "0.1.0",
  "description": "Pack, encrypt, and sync browser profiles across machines",
  "type": "module",
  "bin": {
    "browserpack": "./dist/bin/browserpack.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/browserpack.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/ test/",
    "format": "prettier --write 'src/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser",
    "profile",
    "sync",
    "backup",
    "chrome",
    "encrypt"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "argon2": "^0.44.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "tar": "^7.5.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
